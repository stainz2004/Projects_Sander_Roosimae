<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="26.02.2026-1" author="Sander R">
        <createTable tableName="seating_type">
            <column name="id" type="bigserial" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="26.02.2026-2" author="Sander R">
        <createTable tableName="seating">
            <column name="id" type="bigserial" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="type_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_seating_type"
                             references="seating_type(id)"/>
            </column>
            <column name="max_people" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="26.02.2026-3" author="Sander R">
        <createTable tableName="reservation">
            <column name="id" type="bigserial" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="seating_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_reservation_seating"
                             references="seating(id)"/>
            </column>
            <column name="start_time" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="26.02.2026-4" author="Sander R">
        <createTable tableName="seating_preference">
            <column name="id" type="bigserial" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="26.02.2026-5" author="Sander R">
        <createTable tableName="seating_seating_preference">
            <column name="seating_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_ssp_seating"
                             references="seating(id)"/>
            </column>
            <column name="preference_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_ssp_preference"
                             references="seating_preference(id)"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="seating_seating_preference"
                       columnNames="seating_id, preference_id"
                       constraintName="pk_seating_seating_preference"/>
    </changeSet>
</databaseChangeLog>
