# =====================
# Spring Boot / Gradle
# =====================

# PostgreSQL Docker volume data
backend/postgres-data/

# Build output
backend/build/
backend/out/
backend/bin/
backend/target/
backend/.env

# Gradle cache (not the wrapper itself)
backend/.gradle/
.gradle/

# Compiled classes and build artifacts in build dirs only
backend/build/**/*.class
backend/build/**/*.jar
backend/build/**/*.war
backend/build/**/*.ear

# Spring Boot local config
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-local.yml

# Spring Tool Suite
backend/.apt_generated
backend/.factorypath
backend/.springBeans
backend/.sts4-cache

# NetBeans
backend/.nb-gradle/

# =====================
# React / TypeScript / Node
# =====================
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.cache/
frontend/.vite/

# Environment files
frontend/.env
frontend/.env.local
frontend/.env.*.local

# TypeScript build info
frontend/*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# =====================
# IDEs & Editors
# =====================

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/

# Eclipse
.classpath
.project
.settings/

# =====================
# OS & System Files
# =====================
.DS_Store
Thumbs.db
desktop.ini

# =====================
